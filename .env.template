# .env.template — 复制为 .env 并填入实际值

# DeepSeek API (api.deepseek.com)
# 在 https://platform.deepseek.com/api_keys 获取
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Azure AI Search (Foundry IQ)
# 在 Azure Portal → agents-league Search Service → Keys
AI_SEARCH_ENDPOINT=https://agents-league.search.windows.net
AI_SEARCH_KEY=your-search-admin-key
AI_SEARCH_INDEX=foundry-iq-index

# Teams Bot
# 在 Azure Portal → Bot Channels Registration 中获取
TEAMS_APP_ID=your-bot-app-id
TEAMS_APP_PASSWORD=your-bot-app-password

# Azure Storage (JSON归档)
STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
STORAGE_CONTAINER=pipeline-archive

# Pipeline
MAX_GATEKEEPING_ROUNDS=3
# DEMO_MODE=true  # 开启Demo模式（跳过Teams/FIQ实际调用）
